                                                                x-model="item.quantity"
                                                            />
                                                            <button
                                                                type="button"
                                                                class="btn btn-primary btn-soft size-5.5 min-h-0 rounded-sm p-0"
                                                                @click="addQuantity(item.id)"
                                                            >
                                                                <span class="icon-[tabler--plus] size-3.5 shrink-0"></span>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>
                                                    <span>$</span><input name="price[]" disabled type="text" class="max-w-4" :value="item.price" />
                                                </td>
                                                <td>
                                                    <button
                                                        @click="eraseItem(item.id)"
                                                        type="button"
                                                        class="btn btn-circle btn-error btn-text btn-sm"
                                                        aria-label="Action button"
                                                    >                                                        <span class="icon-[tabler--trash] size-5"></span></button>
                                                </td>
                                            </tr>

                                        </template>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="flex justify-end">
                            <h1 class="text-xl ">
                                Total: $<input name="total" class="font-semibold w-10" disabled :value="total" />
                            </h1>
                        </div>
                    </div>
                </div>
                <!-- Combinaciones -->
                <div class="h-full w-full">
                    <h1 class="text-3xl mb-5 text-black">
                        Combinaciones
                    </h1>
                    <div class="flex flex-wrap gap-10 items-center  max-h-[65vh] bg-teal-200 py-7 px-5 overflow-auto">
                        <!-- Cards -->
                    </div>
                </div>
                <!-- Metodo de Pago -->
                <div class="h-full w-full">
                    <h1 class="text-3xl mb-5 text-black">
                        Metodo de Pago
                    </h1>
                    <div
                        class="flex flex-wrap gap-10 items-center justify-center  max-h-[65vh] bg-white py-7 px-5 overflow-auto"
                    >
                        <select name="payment_method" class="select max-w-sm appearance-none" aria-label="select">
                            <option disabled selected>
                                --Seleccione un metodo de pago--
                            </option>
                            <option value="Tarjeta">
                                Tarjeta
                            </option>
                            <option value="Efectivo">
                                Efectivo
                            </option>
                        </select>

                        <div>
                            <button type="submit" class="btn btn-success">Confirmar Pedido</button>
                        </div>
                    </div>
                </div>
