                <!-- Pedidos -->
                <div class="h-full w-full ">
                    <h1 class="text-3xl mb-5 text-black">
                        Pedidos
                    </h1>
                    <div
                        class="flex flex-wrap flex-col gap-10 justify-between min-h-[65vh] max-h-[65vh] bg-white py-7 px-5 overflow-auto"
                    >
                        <div class="w-full">
                            <div class="overflow-x-auto flex flex-col justify-center text-center">
                                <table class="table-xs table">
                                    <!-- head -->
                                    <thead>
                                        <tr>
                                            <th>
                                                Nombre
                                            </th>
                                            <th>
                                                Cantidad
                                            </th>
                                            <th>
                                                Precio
                                            </th>
                                            <th>
                                                Accion
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <template x-for="item in items" :key="item.id">
                                            <tr>
                                                <td>
                                                    <div class="flex items-center gap-3">
                                                        <div class="avatar">
                                                            <div class="bg-base-content/10 h-10 w-10 rounded-md">
                                                                <img src="{{ asset('resources/images/marquesita.jpg') }}" alt="product image" />
                                                            </div>
                                                        </div>
                                                        <div>
                                                            <div class="text-md text-black">
                                                                <input name="name[]" disabled type="text" class="w-fit" :value="item.name" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div class="max-w-32">
                                                        <div class="input items-center">
                                                            <button
                                                                type="button"
                                                                class="btn btn-primary btn-soft size-5.5 min-h-0 rounded-sm p-0"
                                                                @click="removeQuantity(item.id)"
                                                            >
                                                                <span class="icon-[tabler--minus] size-3.5 shrink-0"></span>
                                                            </button>
                                                            <input
                                                                name="quantity[]"
                                                                class="text-center"
