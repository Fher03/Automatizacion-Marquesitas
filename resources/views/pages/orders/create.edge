        </form>
    </div>

    <script>
        function productHandler() {
            return {
                items: [],
                currentItem: null,
                toppingsList: [ "Fresa", "Platano", "Nuez", "Nutella" ],
                total: 0,
                startNewItem(name) {
                    this.currentItem = {
                        id: this.items.length + 1,
                        name: name,
                        toppings: [],
                        price: 30,
                        quantity: 1
                    };
                },
                toggleSelection(topping) {
                    const toppings = this.currentItem.toppings;
                    if (toppings.includes(topping)) {
                        this.currentItem.toppings = toppings.filter(t => t !== topping);
                    } else {
                        toppings.push(topping);
                    }
                },
                confirmItem() {
                    if (this.currentItem.toppings.length === 0) {
                        alert("Debes agregar al menos un ingrediente");
                        return;
                    }
                    const toppingsQuantity = this.currentItem.toppings.length;
                    this.currentItem.price += toppingsQuantity * 10 - 10;
                    this.items.push(this.currentItem);
                    this.total += this.currentItem.price
                    this.currentItem = null;
                
                    // Limpia los checkboxes visualmente
                    setTimeout(() => {
                        document.querySelectorAll("input[type=checkbox]").forEach(cb => cb.checked = false);
                    }, 0);
                },                
                cancelItem() {
                    this.currentItem = null;
                    console.log(this.currentItem)
                },
                eraseItem(id) {
                    const itemToRemove = this.items.find(item => item.id === id)
                    if (!itemToRemove) return;
                
                    this.total -= itemToRemove.price * itemToRemove.quantity
                    this.items = this.items.filter(item => item.id !== id)
                },
                addQuantity(id) {
                    const item = this.items.find(item => item.id === id)
                    if (!item) return;
                
                    item.quantity += 1
                    this.total += item.price
                },
                removeQuantity(id) {
                    const item = this.items.find(item => item.id === id)
                    if (!item || item.quantity <= 1) return;
                
                    item.quantity -= 1
                    this.total -= item.price
                }                
            };
        }
    </script>

@end
